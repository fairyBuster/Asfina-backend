# Django
SECRET_KEY=change-me
DEBUG=True

# MySQL
DATABASE_NAME=django_db
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=3306

# App domain used for Jayapay callback notify URL
# Example: myapp.example.com (no protocol)
APP_DOMAIN=api.ggeeccss.xyz

# Jayapay integration
# Enable/disable Jayapay integration
JAYAPAY_ENABLED=False

# Your merchant code from Jayapay dashboard
JAYAPAY_MERCHANT_CODE=

# Paste RSA PRIVATE KEY body ONLY (without BEGIN/END headers)
# Multiline is supported. Example:
# JAYAPAY_PRIVATE_KEY="""
# MIIEowIBAAKCAQEAu...
# ...rest-of-key-lines...
# """
JAYAPAY_PRIVATE_KEY=

# Klikpay integration
# Enable/disable Klikpay integration
KLIKPAY_ENABLED=False

# Provider API URL for creating payment orders
KLIKPAY_API_URL=

# Your Klikpay merchant code
KLIKPAY_MERCHANT_CODE=

# Shared secret or signing key used to sign requests
KLIKPAY_SECRET_KEY=

# JWT settings
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Gunicorn overrides (optional, for Linux deploy)
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=9
GUNICORN_THREADS=1
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_LOGLEVEL=info
GUNICORN_WORKER_CLASS=sync